kubeconfig
*.kubeconfig
.kubeconfig-*

# ============================================================================
# Docker
# ============================================================================
.docker/

# ============================================================================
# IDE
# ============================================================================
.vscode/
.idea/
*.swp
*.swo
*~

# ============================================================================
# OS
# ============================================================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================================================
# Logs & temp files
# ============================================================================
*.log
*.tmp
/tmp/
task-requirements.md

# ============================================================================
# Secrets — NEVER COMMIT
# ============================================================================
# This project prefers Workload Identity Federation (keyless auth).
# SA keys are only a fallback for IAM-restricted projects, and even
# then they live in GitHub Secrets — never in the repo.
*.pem
*.pem.pub
*.key
*-sa-key.json
gcp-sa-key*.json
service-account-*.json
credentials.json
.env
.env.*
!.env.example